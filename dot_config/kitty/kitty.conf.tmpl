# Font configuration
font_family      CommitMono Nerd Font Mono
bold_font        auto
italic_font      auto
bold_italic_font auto
font_size        11.0

# Platform-specific overrides (e.g. macos.conf bumps font_size)
include ${KITTY_OS}.conf

# Always render ligatures
disable_ligatures never

# Font fallback — backup font for the technical/symbol block
# (U+2300-U+27FF) that CommitMono is missing pieces of. Menlo on
# macOS (ships with the OS); Meslo LG L on Linux — Meslo is an open,
# redistributable derivative of Menlo (`ttf-meslo` on AUR), installed
# specifically as a same-metrics stand-in since real Menlo isn't
# redistributable there. Font name still differs (Menlo vs Meslo LG
# L), so the OS branch stays even with both fonts installed. Without
# an explicit fallback this whole block, including the
# U+2721-U+2749 stars/snowflakes sub-block Claude Code's
# thinking-spinner animation cycles through, breaks: fontconfig
# picks a different, inconsistent substitute font per codepoint.
# The Noto Color Emoji ranges below are deliberately kept
# non-overlapping with it (gaps at U+2714 and the whole
# U+2721-U+2749 stars/snowflakes sub-block, except U+2728 sparkles)
# rather than overridden after the fact — kitty has a bug in
# coalesce_symbol_maps() (kitty/fonts/render.py) where a codepoint
# covered by font A, then font B, then font A again (non-adjacent,
# overlapping symbol_map rules) fails to render even though A and B
# both have real glyph data. Most of that sub-block also isn't
# Emoji_Presentation=Yes by default anyway, so the fallback font is
# the more correct rendering regardless. Same reason U+2717-U+2718
# (git-status ✗/✘, wanted plain so it inherits terminal fg color) is
# carved out of the emoji range as U+2715-U+2716,U+2719-U+2720
# instead of a plain U+2715-U+2720 rule with a separate overriding
# U+2717-U+2718 rule after it — that nested-overlap form hit the
# same coalescing bug and silently dropped the carve-out.
symbol_map U+1F300-U+1FAFF Noto Color Emoji
symbol_map U+2B50-U+2B55   Noto Color Emoji
{{- if eq .chezmoi.os "darwin" }}
symbol_map U+2300-U+27FF   Menlo
{{- else }}
symbol_map U+2300-U+27FF   Meslo LG L
{{- end }}
symbol_map U+23F0-U+23F9   Noto Color Emoji
symbol_map U+2614-U+2712   Noto Color Emoji
symbol_map U+2715-U+2716,U+2719-U+2720 Noto Color Emoji
symbol_map U+2728-U+2728   Noto Color Emoji
symbol_map U+274A-U+276B   Noto Color Emoji
symbol_map U+23BE-U+23BF   Noto Sans Symbols
symbol_map U+2717-U+2718   JetBrains Mono
symbol_map U+0300-U+036F   JetBrains Mono
symbol_map U+23FA-U+23FA   STIX Two Math

# Theme
include dracula.conf

# Tab bar — hide when only one tab open
tab_bar_min_tabs 2
tab_bar_edge     bottom
tab_bar_style    powerline

# Window
remember_window_size  yes
initial_window_width  640
initial_window_height 400
window_padding_width  2

# Cursor
cursor_shape          block
cursor_blink_interval 0

# Mouse
mouse_hide_wait 3.0

# Performance
repaint_delay   10
input_delay     3
sync_to_monitor yes

# Bell
enable_audio_bell    no
visual_bell_duration 0.0

# Clipboard
copy_on_select clipboard

# Fix backspace — force standard DEL (\x7f) regardless of keyboard protocol
map backspace send_text all \x7f


# BEGIN_KITTY_THEME
# Dracula
include current-theme.conf
# END_KITTY_THEME