#!/bin/zsh

# used in .gitconfig
export BRANCHPREFIX="initials"
{{- if eq .class "work" }}

# used by https://github.com/ankitpokhrel/jira-cli
export JIRA_AUTH_TYPE="basic"
export JIRA_API_TOKEN="{{ (bitwarden "item" "jira-api-token").login.password }}"

# Atlassian API for attachment downloads
export ATLASSIAN_CLOUD_ID="{{ (bitwarden "item" "atlassian-cloud-id").login.password }}"
export ATLASSIAN_EMAIL="{{ (bitwarden "item" "atlassian-api-token").login.username }}"
export ATLASSIAN_API_TOKEN="{{ (bitwarden "item" "atlassian-api-token").login.password }}"
{{- end }}

# Unlock BitWarden and export session (skip if already unlocked)
# Run `bw login` first if not yet logged in
if ! bw status 2>/dev/null | grep -q '"status":"unlocked"'; then
  export BW_SESSION=$(bw unlock --raw)
fi
