#!/bin/zsh

# used in .gitconfig
export BRANCHPREFIX="wh"
{{- if eq .class "work" }}

# used by https://github.com/ankitpokhrel/jira-cli
export JIRA_AUTH_TYPE="basic"
export JIRA_API_TOKEN="{{ (bitwarden "item" "jira-api-token").login.password }}"

# Atlassian API for attachment downloads
export ATLASSIAN_CLOUD_ID="{{ (bitwarden "item" "atlassian-cloud-id").login.password }}"
export ATLASSIAN_EMAIL="{{ (bitwarden "item" "jira-api-token").login.username }}"
export ATLASSIAN_API_TOKEN="{{ (bitwarden "item" "jira-api-token").login.password }}"

# Azure DevOps PAT (dev.azure.com/igs-vsts) — not nuget-specific, reused wherever an
# Azure DevOps token is needed. Regenerate at:
#   https://dev.azure.com/igs-vsts/_usersSettings/tokens
export Azure_API_TOKEN="{{ (bitwarden "item" "azure-api-token").login.password }}"

# Feeds dotnet/NuGet restore against the IGS Artifacts feed (CRM repo). Sidesteps the
# flaky macOS MSAL broker used by `dotnet restore --interactive` / CredentialProvider.Microsoft.
export VSS_NUGET_EXTERNAL_FEED_ENDPOINTS='{"endpointCredentials": [{"endpoint":"https://pkgs.dev.azure.com/igs-vsts/_packaging/IGS%40Local/nuget/v3/index.json","username":"docs","password":"{{ (bitwarden "item" "azure-api-token").login.password }}"}]}'
{{- end }}

# Unlock BitWarden once per login, cache session in runtime dir (tmpfs, cleared on logout)
# Run `bw login` first if not yet logged in
BW_SESSION_CACHE="${XDG_RUNTIME_DIR:-/tmp}/bw_session"
if [ -f "$BW_SESSION_CACHE" ]; then
  export BW_SESSION=$(cat "$BW_SESSION_CACHE")
fi
if ! bw status --session "$BW_SESSION" 2>/dev/null | grep -q '"status":"unlocked"'; then
  export BW_SESSION=$(bw unlock --raw)
  install -m 600 /dev/null "$BW_SESSION_CACHE"
  printf '%s' "$BW_SESSION" > "$BW_SESSION_CACHE"
fi
